<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="48dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp"
        android:background="#FFFFFF">

        <!-- Back button on its own row -->
        <ImageButton
            android:id="@+id/btn_back_settings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_chevron_left"
            android:background="@drawable/bg_back_btn_circle"
            android:padding="6dp"
            android:contentDescription="Back"
            android:layout_marginBottom="8dp"/>

        <!-- Title on separate row below -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="App "
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#1C1C1E"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#5B8DCC"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <include layout="@layout/view_color_strip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── ACCOUNT ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCOUNT"
                android:textSize="11sp"
                android:textColor="#8E8E93"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <!-- Edit Name -->
                    <LinearLayout
                        android:id="@+id/row_edit_name"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="👤" android:textSize="18sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Edit Name"
                            android:textSize="15sp" android:textColor="#1C1C1E"/>
                        <TextView android:id="@+id/tv_current_name"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="" android:textSize="13sp" android:textColor="#8E8E93"
                            android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textSize="20sp" android:textColor="#C7C7CC"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F2F2F7" android:layout_marginStart="44dp"/>

                    <!-- Edit Birthday -->
                    <LinearLayout
                        android:id="@+id/row_edit_birthday"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🎂" android:textSize="18sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Edit Birthday"
                            android:textSize="15sp" android:textColor="#1C1C1E"/>
                        <TextView android:id="@+id/tv_current_birthday"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="" android:textSize="13sp" android:textColor="#8E8E93"
                            android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textSize="20sp" android:textColor="#C7C7CC"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F2F2F7" android:layout_marginStart="44dp"/>

                    <!-- Edit School -->
                    <LinearLayout
                        android:id="@+id/row_edit_school"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🏫" android:textSize="18sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Edit School"
                            android:textSize="15sp" android:textColor="#1C1C1E"/>
                        <TextView android:id="@+id/tv_current_school"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="" android:textSize="13sp" android:textColor="#8E8E93"
                            android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textSize="20sp" android:textColor="#C7C7CC"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F2F2F7" android:layout_marginStart="44dp"/>

                    <!-- Edit Year Level -->
                    <LinearLayout
                        android:id="@+id/row_edit_year"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🎓" android:textSize="18sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Edit Year Level"
                            android:textSize="15sp" android:textColor="#1C1C1E"/>
                        <TextView android:id="@+id/tv_current_year"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="" android:textSize="13sp" android:textColor="#8E8E93"
                            android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textSize="20sp" android:textColor="#C7C7CC"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SUBJECTS ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUBJECTS"
                android:textSize="11sp"
                android:textColor="#8E8E93"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:id="@+id/btn_manage_subjects"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📚" android:textSize="18sp" android:layout_marginEnd="12dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Manage Subjects"
                        android:textSize="15sp" android:textColor="#1C1C1E"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="#C7C7CC"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── NOTIFICATIONS ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOTIFICATIONS"
                android:textSize="11sp"
                android:textColor="#8E8E93"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <!-- Daily Reminder Toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔔" android:textSize="18sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Daily Log Reminder"
                            android:textSize="15sp" android:textColor="#1C1C1E"/>
                        <Switch
                            android:id="@+id/switch_reminder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F2F2F7" android:layout_marginStart="44dp"/>

                    <!-- Reminder Time -->
                    <LinearLayout
                        android:id="@+id/row_reminder_time"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:visibility="gone">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⏰" android:textSize="18sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Reminder Time"
                            android:textSize="15sp" android:textColor="#1C1C1E"/>
                        <TextView android:id="@+id/tv_reminder_time"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="8:00 AM" android:textSize="13sp" android:textColor="#5B8DCC"
                            android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textSize="20sp" android:textColor="#C7C7CC"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── DATA ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATA"
                android:textSize="11sp"
                android:textColor="#8E8E93"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <!-- Export CSV -->
                    <LinearLayout
                        android:id="@+id/btn_export_csv"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📤" android:textSize="18sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Export Logs as CSV"
                            android:textSize="15sp" android:textColor="#1C1C1E"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textSize="20sp" android:textColor="#C7C7CC"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F2F2F7" android:layout_marginStart="44dp"/>

                    <!-- Delete All Logs -->
                    <LinearLayout
                        android:id="@+id/btn_delete_logs"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🗑️" android:textSize="18sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Delete All Logs"
                            android:textSize="15sp" android:textColor="#D95F6A"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textSize="20sp" android:textColor="#C7C7CC"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F2F2F7" android:layout_marginStart="44dp"/>

                    <!-- Reset All Data -->
                    <LinearLayout
                        android:id="@+id/btn_reset_data"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⚠️" android:textSize="18sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Reset All Data"
                            android:textSize="15sp" android:textColor="#D95F6A"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textSize="20sp" android:textColor="#C7C7CC"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── APP ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APP"
                android:textSize="11sp"
                android:textColor="#8E8E93"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <!-- Version -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="ℹ️" android:textSize="18sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Version"
                            android:textSize="15sp" android:textColor="#1C1C1E"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="1.0.0" android:textSize="13sp" android:textColor="#8E8E93"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F2F2F7" android:layout_marginStart="44dp"/>

                    <!-- About -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="About ClassPulse"
                            android:textSize="13sp" android:textColor="#1C1C1E"
                            android:fontFamily="sans-serif-bold" android:layout_marginBottom="4dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="ClassPulse helps students track, reflect on, and improve their class engagement. All data is stored locally — no internet required."
                            android:textSize="12sp" android:textColor="#8E8E93"
                            android:lineSpacingMultiplier="1.4"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>