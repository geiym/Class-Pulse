<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HELLO HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="52dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hello, "
                        android:textSize="22sp"
                        android:textColor="#1A1A2E"
                        android:fontFamily="sans-serif-bold"/>
                    <TextView
                        android:id="@+id/tv_profile_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Irene"
                        android:textSize="22sp"
                        android:textColor="#7B96D4"
                        android:fontFamily="sans-serif-bold"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" !"
                        android:textSize="22sp"
                        android:textColor="#1A1A2E"
                        android:fontFamily="sans-serif-bold"/>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_settings"
                    android:background="@drawable/bg_back_btn_circle"
                    android:padding="7dp"
                    android:contentDescription="Settings"/>
            </LinearLayout>

            <include layout="@layout/view_color_strip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- BODY -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="16dp">

            <!-- Buttons row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">

                <ImageButton
                    android:id="@+id/btn_save_id"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="40dp"
                    android:src="@drawable/ic_check"
                    android:background="@drawable/bg_back_btn_circle"
                    android:padding="6dp"
                    android:visibility="gone"
                    android:contentDescription="Save"/>

                <ImageButton
                    android:id="@+id/btn_edit_id"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_edit"
                    android:background="@drawable/bg_back_btn_circle"
                    android:padding="6dp"
                    android:contentDescription="Edit ID card"/>
            </RelativeLayout>

            <!-- ID CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_profile_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- TOP COLORED SECTION -->
                    <RelativeLayout
                        android:id="@+id/ll_id_top"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="130dp"
                        android:padding="14dp">

                        <View
                            android:id="@+id/view_color_dot_profile"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentEnd="true"
                            android:visibility="gone"/>

                        <!-- LEFT COLUMN — margin reduced to 4dp -->
                        <LinearLayout
                            android:id="@+id/ll_id_left"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toStartOf="@+id/fl_avatar"
                            android:layout_marginEnd="4dp"
                            android:orientation="vertical">

                            <!-- ID-CARD pill -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="6dp"
                                android:background="@drawable/bg_id_label"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="4dp">

                                <ImageView
                                    android:id="@+id/iv_id_icon"
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_marginEnd="6dp"
                                    android:contentDescription="ID icon"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/ic_default_avatar"
                                    android:clipToOutline="true"
                                    android:background="@drawable/bg_circle_clip"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif-bold"
                                    android:paddingEnd="6dp"
                                    android:text="ID-CARD"
                                    android:textColor="#C2607A"
                                    android:textSize="12sp"/>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_label_icon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tap to change icons"
                                android:textSize="8sp"
                                android:textColor="#C2607A"
                                android:layout_marginBottom="2dp"
                                android:visibility="gone"/>

                            <!-- Traffic light dots -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="8dp"
                                android:orientation="horizontal">
                                <View android:layout_width="11dp" android:layout_height="11dp" android:layout_marginEnd="5dp" android:background="@drawable/dot_red"/>
                                <View android:layout_width="11dp" android:layout_height="11dp" android:layout_marginEnd="5dp" android:background="@drawable/dot_yellow"/>
                                <View android:layout_width="11dp" android:layout_height="11dp" android:background="@drawable/dot_green"/>
                            </LinearLayout>

                            <!-- Row 1: Name | Birthday -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="6dp"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginEnd="6dp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Name:"
                                        android:textColor="#C2607A"
                                        android:textSize="9sp"/>
                                    <TextView
                                        android:id="@+id/tv_id_name"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Student"
                                        android:textColor="#1A1A2E"
                                        android:fontFamily="sans-serif-bold"
                                        android:textSize="12sp"/>
                                    <EditText
                                        android:id="@+id/et_id_name"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:hint="Name"
                                        android:textSize="12sp"
                                        android:textColor="#1A1A2E"
                                        android:background="@drawable/bg_edit_field"
                                        android:padding="2dp"
                                        android:maxLines="1"
                                        android:visibility="gone"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Birthday:"
                                        android:textColor="#C2607A"
                                        android:textSize="9sp"/>
                                    <TextView
                                        android:id="@+id/tv_id_birthday"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text=""
                                        android:textColor="#1A1A2E"
                                        android:fontFamily="sans-serif-bold"
                                        android:textSize="12sp"/>
                                    <EditText
                                        android:id="@+id/et_id_birthday"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:hint="Birthday"
                                        android:textSize="12sp"
                                        android:textColor="#1A1A2E"
                                        android:background="@drawable/bg_edit_field"
                                        android:padding="2dp"
                                        android:maxLines="1"
                                        android:visibility="gone"/>
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Row 2: School | Year Level -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginEnd="6dp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="School:"
                                        android:textColor="#C2607A"
                                        android:textSize="9sp"/>
                                    <TextView
                                        android:id="@+id/tv_id_school"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text=""
                                        android:textColor="#1A1A2E"
                                        android:fontFamily="sans-serif-bold"
                                        android:textSize="12sp"/>
                                    <EditText
                                        android:id="@+id/et_id_school"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:hint="School"
                                        android:textSize="12sp"
                                        android:textColor="#1A1A2E"
                                        android:background="@drawable/bg_edit_field"
                                        android:padding="2dp"
                                        android:maxLines="1"
                                        android:visibility="gone"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Year Level:"
                                        android:textColor="#C2607A"
                                        android:textSize="9sp"/>
                                    <TextView
                                        android:id="@+id/tv_id_year"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text=""
                                        android:textColor="#1A1A2E"
                                        android:fontFamily="sans-serif-bold"
                                        android:textSize="12sp"/>
                                    <EditText
                                        android:id="@+id/et_id_year"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:hint="Year Level"
                                        android:textSize="12sp"
                                        android:textColor="#1A1A2E"
                                        android:background="@drawable/bg_edit_field"
                                        android:padding="2dp"
                                        android:maxLines="1"
                                        android:visibility="gone"/>
                                </LinearLayout>
                            </LinearLayout>

                        </LinearLayout>

                        <!-- RIGHT: Avatar — shrunk to 80x95dp, closer to text -->
                        <FrameLayout
                            android:id="@+id/fl_avatar"
                            android:layout_width="80dp"
                            android:layout_height="95dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true">

                            <ImageView
                                android:id="@+id/iv_profile_avatar"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="Profile avatar"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_default_avatar"/>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_avatar_bracket"/>

                            <TextView
                                android:id="@+id/tv_label_avatar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom"
                                android:text="Change ID picture"
                                android:textSize="7sp"
                                android:textColor="#C2607A"
                                android:gravity="center"
                                android:background="#80FFFFFF"
                                android:padding="2dp"
                                android:visibility="gone"/>
                        </FrameLayout>

                    </RelativeLayout>

                    <!-- BARCODE SECTION -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/white"
                        android:paddingStart="14dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="6dp">

                        <com.classpulse.views.BarcodeView
                            android:id="@+id/barcode_view"
                            android:layout_width="160dp"
                            android:layout_height="28dp"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STREAK CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#5B8DE8">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="18dp">

                    <LinearLayout
                        android:id="@+id/ll_fire_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:background="@drawable/bg_fire_badge"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔥" android:textSize="12sp"/>
                        <TextView android:id="@+id/tv_streak_count_badge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" android:textSize="11sp" android:textColor="@color/white" android:fontFamily="sans-serif-bold" android:layout_marginStart="3dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Keep it going!" android:textSize="13sp" android:textColor="@color/white" android:fontFamily="sans-serif-bold" android:layout_marginBottom="4dp"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:id="@+id/tv_streak_number" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" android:textSize="46sp" android:textColor="@color/white" android:fontFamily="sans-serif-black"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" day streak" android:textSize="16sp" android:textColor="#DDEEFF" android:fontFamily="sans-serif-medium" android:layout_marginBottom="10dp"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Log today's class to extend your streak" android:textSize="11sp" android:textColor="#BBD4FF" android:fontFamily="sans-serif"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- PERSONAL BESTS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Personal Bests"
                android:textSize="17sp"
                android:textColor="#1A1A2E"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="10dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginBottom="14dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="100dp" android:layout_columnWeight="1" android:layout_marginEnd="6dp" android:layout_marginBottom="8dp" android:background="@drawable/bg_bento_green" android:orientation="vertical" android:gravity="bottom" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📈" android:textSize="18sp" android:layout_marginBottom="2dp"/>
                    <TextView android:id="@+id/tv_best_participation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="89%" android:textSize="22sp" android:fontFamily="sans-serif-black" android:textColor="#2E7D52"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Best participation" android:textSize="9sp" android:fontFamily="sans-serif-bold" android:textColor="#64748B"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="100dp" android:layout_columnWeight="1" android:layout_marginStart="6dp" android:layout_marginBottom="8dp" android:background="@drawable/bg_bento_blue" android:orientation="vertical" android:gravity="bottom" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📅" android:textSize="18sp" android:layout_marginBottom="2dp"/>
                    <TextView android:id="@+id/tv_classes_logged" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18" android:textSize="22sp" android:fontFamily="sans-serif-black" android:textColor="#1A5FA8"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Classes Logged" android:textSize="9sp" android:fontFamily="sans-serif-bold" android:textColor="#64748B"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="100dp" android:layout_columnWeight="1" android:layout_marginEnd="6dp" android:background="@drawable/bg_bento_yellow" android:orientation="vertical" android:gravity="bottom" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡" android:textSize="18sp" android:layout_marginBottom="2dp"/>
                    <TextView android:id="@+id/tv_high_streak" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3×" android:textSize="22sp" android:fontFamily="sans-serif-black" android:textColor="#B45309"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="High in a row" android:textSize="9sp" android:fontFamily="sans-serif-bold" android:textColor="#64748B"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="100dp" android:layout_columnWeight="1" android:layout_marginStart="6dp" android:background="@drawable/bg_bento_purple" android:orientation="vertical" android:gravity="bottom" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👑" android:textSize="18sp" android:layout_marginBottom="2dp"/>
                    <TextView android:id="@+id/tv_common_mood_emoji" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😊" android:textSize="22sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Most Common Mood" android:textSize="9sp" android:fontFamily="sans-serif-bold" android:textColor="#64748B"/>
                </LinearLayout>

            </GridLayout>

            <!-- YOUR CLASS VIBE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Class Vibe"
                android:textSize="17sp"
                android:textColor="#1A1A2E"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <TextView android:layout_width="50dp" android:layout_height="50dp" android:text="😄" android:textSize="32sp" android:gravity="center"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
                            <TextView android:id="@+id/tv_vibe_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="The Enthusiast" android:textSize="15sp" android:fontFamily="sans-serif-bold" android:textColor="#1A1A2E"/>
                            <TextView android:id="@+id/tv_vibe_desc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="You're mostly happy &amp; engaged in class!" android:textSize="11sp" android:textColor="#64748B" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😊 " android:textSize="13sp"/>
                        <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:text="Happy" android:textSize="11sp" android:textColor="#1A1A2E" android:fontFamily="sans-serif-medium"/>
                        <ProgressBar android:id="@+id/pb_vibe_happy" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_height="7dp" android:layout_weight="1" android:progress="55" android:progressDrawable="@drawable/progress_bar_green" android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/tv_vibe_happy_pct" android:layout_width="32dp" android:layout_height="wrap_content" android:text="55%" android:textSize="11sp" android:textColor="#4CAF82" android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😐 " android:textSize="13sp"/>
                        <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:text="Neutral" android:textSize="11sp" android:textColor="#1A1A2E" android:fontFamily="sans-serif-medium"/>
                        <ProgressBar android:id="@+id/pb_vibe_neutral" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_height="7dp" android:layout_weight="1" android:progress="25" android:progressDrawable="@drawable/progress_bar_gray" android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/tv_vibe_neutral_pct" android:layout_width="32dp" android:layout_height="wrap_content" android:text="25%" android:textSize="11sp" android:textColor="#90A4AE" android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😰 " android:textSize="13sp"/>
                        <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:text="Stressed" android:textSize="11sp" android:textColor="#1A1A2E" android:fontFamily="sans-serif-medium"/>
                        <ProgressBar android:id="@+id/pb_vibe_stressed" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_height="7dp" android:layout_weight="1" android:progress="20" android:progressDrawable="@drawable/progress_bar_red" android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/tv_vibe_stressed_pct" android:layout_width="32dp" android:layout_height="wrap_content" android:text="20%" android:textSize="11sp" android:textColor="#E57373" android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>