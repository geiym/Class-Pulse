                        <TextView android:id="@+id/tv_mood_neutral_pct" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-black" android:text="0%" android:textColor="#5C7FC4" android:textSize="18sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-bold" android:text="Neutral" android:textColor="#94A3B8" android:textSize="10sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1" app:cardBackgroundColor="@color/white" app:cardCornerRadius="20dp" app:cardElevation="3dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
