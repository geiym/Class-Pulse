<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- BLUE HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_home"
            android:paddingStart="20dp"
            android:paddingTop="48dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your summary,"
                    android:textColor="#CCE0FF"
                    android:textSize="13sp"/>

                <!-- Name + tab now stacked vertically -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:orientation="vertical">

                    <!-- Name + star -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_user_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="Irene"
                            android:textColor="@color/white"
                            android:textSize="26sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text=" ⭐"
                            android:textSize="20sp"/>

                    </LinearLayout>

                    <!-- Tab toggle below name -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_toggle_container"
                        android:backgroundTint="#C5DBF8"
                        android:orientation="horizontal"
                        android:padding="3dp">

                        <TextView
                            android:id="@+id/tab_weekly"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_tab_selected"
                            android:backgroundTint="#5A8BD0"
                            android:fontFamily="sans-serif-bold"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="Weekly"
                            android:textColor="@color/white"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tab_monthly"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:fontFamily="sans-serif-bold"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="Monthly"
                            android:textColor="#5A8BD0"
                            android:textSize="11sp"/>

                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="April 2026"
                    android:textColor="#CCE0FF"
                    android:textSize="11sp"/>
            </LinearLayout>
        </RelativeLayout>

        <!-- BODY -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="14dp"
            android:paddingTop="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="20dp">

            <!-- ID CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- TOP COLORED SECTION -->
                    <RelativeLayout
                        android:id="@+id/ll_id_top"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FCE4EC"
                        android:minHeight="130dp"
                        android:padding="14dp">

                        <LinearLayout
                            android:id="@+id/ll_id_left"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_toStartOf="@+id/fl_avatar"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="8dp"
                                android:background="@drawable/bg_id_label"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="4dp">

                                <ImageView
                                    android:id="@+id/iv_id_icon"
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:layout_marginEnd="8dp"
                                    android:contentDescription="ID icon"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/ic_default_avatar"/>

                                <TextView
                                    android:id="@+id/tv_id_card_label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif-bold"
                                    android:paddingEnd="8dp"
                                    android:text="ID-CARD"
                                    android:textColor="#C2607A"
                                    android:textSize="13sp"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:orientation="horizontal">
                                <View android:layout_width="13dp" android:layout_height="13dp" android:layout_marginEnd="6dp" android:background="@drawable/dot_red"/>
                                <View android:layout_width="13dp" android:layout_height="13dp" android:layout_marginEnd="6dp" android:background="@drawable/dot_yellow"/>
                                <View android:layout_width="13dp" android:layout_height="13dp" android:background="@drawable/dot_green"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="8dp"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="6dp"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Name:"
                                        android:textColor="#C2607A"
                                        android:textSize="10sp"/>
                                    <TextView
                                        android:id="@+id/tv_id_name"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif-bold"
                                        android:text="Student"
                                        android:textColor="#1A1A2E"
                                        android:textSize="14sp"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Birthday:"
                                        android:textColor="#C2607A"
                                        android:textSize="10sp"/>
                                    <TextView
                                        android:id="@+id/tv_id_birthday"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif-bold"
                                        android:text=""
                                        android:textColor="#1A1A2E"
                                        android:textSize="14sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="6dp"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="School:"
                                        android:textColor="#C2607A"
                                        android:textSize="10sp"/>
                                    <TextView
                                        android:id="@+id/tv_id_school"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif-bold"
                                        android:text=""
                                        android:textColor="#1A1A2E"
                                        android:textSize="14sp"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Year Level:"
                                        android:textColor="#C2607A"
                                        android:textSize="10sp"/>
                                    <TextView
                                        android:id="@+id/tv_id_year"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif-bold"
                                        android:text=""
                                        android:textColor="#1A1A2E"
                                        android:textSize="14sp"/>
                                </LinearLayout>
                            </LinearLayout>

                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/fl_avatar"
                            android:layout_width="80dp"
                            android:layout_height="95dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:layout_marginBottom="-10dp">

                            <ImageView
                                android:id="@+id/iv_profile_avatar"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="Profile avatar"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_default_avatar"/>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_avatar_bracket"/>
                        </FrameLayout>

                    </RelativeLayout>

                    <!-- BARCODE SECTION -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/white"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="6dp">

                        <com.classpulse.views.BarcodeView
                            android:id="@+id/barcode_view"
                            android:layout_width="160dp"
                            android:layout_height="28dp"
                            android:layout_gravity="start"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STAT PILLS -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#EEF2FB">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:minWidth="80dp" android:paddingStart="18dp" android:paddingEnd="18dp" android:paddingTop="14dp" android:paddingBottom="14dp">
                            <TextView android:id="@+id/tv_attendance_rate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textSize="17sp" android:textColor="#2D3F5C" android:fontFamily="sans-serif-black"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Attendance" android:textSize="9sp" android:textColor="#94A3B8"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#EEF2FB">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:minWidth="80dp" android:paddingStart="18dp" android:paddingEnd="18dp" android:paddingTop="14dp" android:paddingBottom="14dp">
                            <TextView android:id="@+id/tv_avg_participation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textSize="17sp" android:textColor="#2D3F5C" android:fontFamily="sans-serif-black"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Avg Part." android:textSize="9sp" android:textColor="#94A3B8"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#EEF2FB">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:minWidth="80dp" android:paddingStart="18dp" android:paddingEnd="18dp" android:paddingTop="14dp" android:paddingBottom="14dp">
                            <TextView android:id="@+id/tv_sessions_stat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="17sp" android:textColor="#2D3F5C" android:fontFamily="sans-serif-black"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sessions" android:textSize="9sp" android:textColor="#94A3B8"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#EEF2FB">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:minWidth="80dp" android:paddingStart="18dp" android:paddingEnd="18dp" android:paddingTop="14dp" android:paddingBottom="14dp">
                            <TextView android:id="@+id/tv_top_subject" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textSize="12sp" android:textColor="#2D3F5C" android:fontFamily="sans-serif-black"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Top subject" android:textSize="9sp" android:textColor="#94A3B8"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- BENTO GRID -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginBottom="12dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginEnd="5dp" android:layout_marginBottom="8dp" android:background="@drawable/bg_bento_green" android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✅" android:textSize="22sp" android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tv_present_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="26sp" android:fontFamily="sans-serif-black" android:textColor="#2E7D52"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Present" android:textSize="11sp" android:fontFamily="sans-serif-bold" android:textColor="#2E7D52"/>
                    <TextView android:id="@+id/tv_present_period" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="This month" android:textSize="9sp" android:textColor="#64748B"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginStart="5dp" android:layout_marginBottom="8dp" android:background="@drawable/bg_bento_blue" android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😊" android:textSize="22sp" android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tv_top_mood" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Happy" android:textSize="18sp" android:fontFamily="sans-serif-black" android:textColor="#1A5FA8"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Top mood" android:textSize="11sp" android:fontFamily="sans-serif-bold" android:textColor="#1A5FA8"/>
                    <TextView android:id="@+id/tv_top_mood_pct" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textSize="9sp" android:textColor="#64748B"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginEnd="5dp" android:background="@drawable/bg_bento_yellow" android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏰" android:textSize="22sp" android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tv_late_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="26sp" android:fontFamily="sans-serif-black" android:textColor="#B45309"/>
                    <TextView android:id="@+id/tv_late_period" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Late this month" android:textSize="11sp" android:fontFamily="sans-serif-bold" android:textColor="#B45309"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginStart="5dp" android:background="@drawable/bg_bento_purple" android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textSize="22sp" android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tv_best_day" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textSize="18sp" android:fontFamily="sans-serif-black" android:textColor="#6B21A8"/>
                    <TextView android:id="@+id/tv_best_day_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Best day" android:textSize="11sp" android:fontFamily="sans-serif-bold" android:textColor="#6B21A8"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="highest engagement" android:textSize="9sp" android:textColor="#64748B"/>
                </LinearLayout>

            </GridLayout>

            <!-- PARTICIPATION CHART -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tv_chart_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PARTICIPATION THIS WEEK"
                        android:textSize="13sp"
                        android:textColor="#1A1A2E"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="10dp"/>

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/bar_chart_participation"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F4F8"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/bg_bento_green" android:gravity="center" android:orientation="vertical">
                            <TextView android:id="@+id/tv_best_day_chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textSize="15sp" android:fontFamily="sans-serif-black" android:textColor="#2E7D52"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ Best" android:textSize="10sp" android:textColor="#4CAF82"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:background="@drawable/bg_bento_pink" android:gravity="center" android:orientation="vertical">
                            <TextView android:id="@+id/tv_worst_day_chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textSize="15sp" android:fontFamily="sans-serif-black" android:textColor="#E57373"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📉 Weakest" android:textSize="10sp" android:textColor="#EF9A9A"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SUBJECTS SCROLL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.02"
                android:text="SUBJECTS · ATTENDANCE"
                android:textColor="#1A1A2E"
                android:textSize="11sp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:scrollbars="none">
                <LinearLayout
                    android:id="@+id/ll_subjects_scroll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

            <!-- MOOD BOXES -->
            <TextView
                android:id="@+id/tv_mood_section_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.02"
                android:text="MOOD THIS MONTH"
                android:textColor="#1A1A2E"
                android:textSize="11sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp">

                <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="100dp" android:layout_marginEnd="8dp" android:layout_weight="1" app:cardBackgroundColor="@color/white" app:cardCornerRadius="20dp" app:cardElevation="3dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😊" android:textSize="28sp" android:layout_marginBottom="4dp"/>
                        <TextView android:id="@+id/tv_mood_happy_pct" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-black" android:text="0%" android:textColor="#4CAF82" android:textSize="18sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-bold" android:text="Happy" android:textColor="#94A3B8" android:textSize="10sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="100dp" android:layout_marginEnd="8dp" android:layout_weight="1" app:cardBackgroundColor="@color/white" app:cardCornerRadius="20dp" app:cardElevation="3dp">
