<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Date Badge -->
        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="56dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_date_badge"
            android:layout_marginEnd="14dp">
            <TextView
                android:id="@+id/tv_log_month"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APR"
                android:textSize="9sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"/>
            <TextView
                android:id="@+id/tv_log_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8"
                android:textSize="22sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-bold"/>
        </LinearLayout>

        <!-- Log Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_log_subject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Discrete Math"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="4dp"/>

            <!-- Chips Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tv_attendance_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Present"
                    android:textSize="11sp"
                    android:textColor="#4CAF50"
                    android:background="@drawable/bg_chip_green"
                    android:paddingStart="8dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="2dp"
                    android:layout_marginEnd="5dp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tv_participation_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="High"
                    android:textSize="11sp"
                    android:textColor="@color/cobalt"
                    android:background="@drawable/bg_chip_blue"
                    android:paddingStart="8dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="2dp"
                    android:layout_marginEnd="5dp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tv_mood_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Focused"
                    android:textSize="11sp"
                    android:textColor="@color/fresh_sky"
                    android:background="@drawable/bg_chip_sky"
                    android:paddingStart="8dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="2dp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_log_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Covered graph theory — Dijkstra's algorithm walkthrough."
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
