<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Participation Bar Chart Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header row: title + week nav -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PARTICIPATION · WEEK"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#8E8E93"
                    android:letterSpacing="0.04"/>

                <ImageButton
                    android:id="@+id/btnWeekPrev"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_chevron_left"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Previous week"/>

                <TextView
                    android:id="@+id/tvWeekRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Apr 21–25"
                    android:textSize="12sp"
                    android:textColor="#1C1C1E"
                    android:layout_marginHorizontal="4dp"/>

                <ImageButton
                    android:id="@+id/btnWeekNext"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_chevron_right"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Next week"/>
            </LinearLayout>

            <!-- Custom bar chart container -->
            <LinearLayout
                android:id="@+id/llCustomBars"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:paddingHorizontal="4dp"/>

            <!-- Pill labels + day names below bars -->
            <LinearLayout
                android:id="@+id/llBarLabels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"/>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#F0F0F0" android:layout_marginVertical="12dp"/>

            <!-- Summary: Present / Avg Part / Top Mood -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvWeekPresent"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="4/5" android:textSize="18sp" android:textStyle="bold"
                        android:textColor="#1C1C1E"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Present" android:textSize="11sp" android:textColor="#8E8E93"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="36dp"
                    android:background="#F0F0F0"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvWeekAvgPart"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Med" android:textSize="18sp" android:textStyle="bold"
                        android:textColor="#1C1C1E"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Avg Part." android:textSize="11sp" android:textColor="#8E8E93"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="36dp"
                    android:background="#F0F0F0"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvWeekTopMood"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="😊" android:textSize="22sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Top mood" android:textSize="11sp" android:textColor="#8E8E93"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Attendance This Week Card (Pie chart) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ATTENDANCE THIS WEEK"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#8E8E93"
                android:letterSpacing="0.04"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChartWeekly"
                    android:layout_width="110dp"
                    android:layout_height="110dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <!-- Present row -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="52dp" android:layout_height="wrap_content"
                            android:text="Present" android:textSize="12sp"
                            android:textColor="#5CAD72" android:textStyle="bold"/>
                        <ProgressBar android:id="@+id/pbWeekPresent"
                            android:layout_width="0dp" android:layout_height="6dp"
                            android:layout_weight="1"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:progressDrawable="@drawable/progress_bar_green"
                            android:progress="80"/>
                        <TextView android:id="@+id/tvWeekPresentCount"
                            android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="4" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="#1C1C1E" android:gravity="end"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- Late row -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="52dp" android:layout_height="wrap_content"
                            android:text="Late" android:textSize="12sp"
                            android:textColor="#E0A050" android:textStyle="bold"/>
                        <ProgressBar android:id="@+id/pbWeekLate"
                            android:layout_width="0dp" android:layout_height="6dp"
                            android:layout_weight="1"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:progressDrawable="@drawable/progress_bar_orange"
                            android:progress="20"/>
                        <TextView android:id="@+id/tvWeekLateCount"
                            android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="1" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="#1C1C1E" android:gravity="end"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- Absent row -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView android:layout_width="52dp" android:layout_height="wrap_content"
                            android:text="Absent" android:textSize="12sp"
                            android:textColor="#D95F6A" android:textStyle="bold"/>
                        <ProgressBar android:id="@+id/pbWeekAbsent"
                            android:layout_width="0dp" android:layout_height="6dp"
                            android:layout_weight="1"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:progressDrawable="@drawable/progress_bar_red"
                            android:progress="0"/>
                        <TextView android:id="@+id/tvWeekAbsentCount"
                            android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="0" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="#D95F6A" android:gravity="end"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Class Check-In Card -->
    <include layout="@layout/card_class_checkin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"/>

</LinearLayout>