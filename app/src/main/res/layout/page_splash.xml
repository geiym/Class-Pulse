<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#5A8BD0">

    <FrameLayout
        android:layout_width="100dp"
        android:layout_height="100dp">
        <View
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/bg_splash_ring"
            android:alpha="0.3"/>
        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_splash_circle">
            <ImageView
                android:id="@+id/iv_onboard_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@mipmap/ic_launcher"/>
        </FrameLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/tv_onboard_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="ClassPulse"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/tv_onboard_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#AACFFF"
        android:textSize="14sp"/>

</LinearLayout>