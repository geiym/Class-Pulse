<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="36dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_chevron_left"
                    android:background="@drawable/bg_back_btn_circle"
                    android:contentDescription="Back"
                    android:layout_marginEnd="10dp"
                    android:padding="6dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Log a "
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#1C1C1E"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Class"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#9B8EC4"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How was today's session?"
                android:textSize="12sp"
                android:textColor="#8E8E93"
                android:layout_marginTop="2dp"
                android:layout_marginStart="46dp"/>

            <!-- Color strip -->
            <include layout="@layout/view_color_strip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginStart="46dp"/>
        </LinearLayout>

        <!-- Body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp">

            <!-- Subject Selector -->
            <LinearLayout
                android:id="@+id/card_subject_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SELECT SUBJECT"
                    android:textSize="11sp"
                    android:textColor="#8E8E93"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="6dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F2F4F7">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp">

                        <Spinner
                            android:id="@+id/spinner_subject"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:paddingHorizontal="14dp"
                            android:paddingEnd="40dp"
                            android:background="@android:color/transparent"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            android:rotation="90"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="14dp"
                            app:tint="#8E8E93"
                            android:contentDescription="dropdown"/>

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Subject shown when launched from schedule -->
            <TextView
                android:id="@+id/tv_subject_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#8E8E93"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <!-- ATTENDANCE -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ATTENDANCE"
                        android:textSize="11sp"
                        android:textColor="#8E8E93"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Present -->
                        <LinearLayout
                            android:id="@+id/btn_present"
                            android:layout_width="0dp"
                            android:layout_height="64dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_attendance_present"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="✅" android:textSize="20sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Present" android:textSize="12sp"
                                android:textColor="#2E7D52" android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Late -->
                        <LinearLayout
                            android:id="@+id/btn_late"
                            android:layout_width="0dp"
                            android:layout_height="64dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_attendance_unselected"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🕐" android:textSize="20sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Late" android:textSize="12sp"
                                android:textColor="#8E8E93"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Absent -->
                        <LinearLayout
                            android:id="@+id/btn_absent"
                            android:layout_width="0dp"
                            android:layout_height="64dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_attendance_unselected"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="❌" android:textSize="20sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Absent" android:textSize="12sp"
                                android:textColor="#8E8E93"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- PARTICIPATION LEVEL -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PARTICIPATION LEVEL"
                        android:textSize="11sp"
                        android:textColor="#8E8E93"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/btn_low"
                            android:layout_width="0dp"
                            android:layout_height="64dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_attendance_unselected"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="👇" android:textSize="20sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Low" android:textSize="12sp"
                                android:textColor="#8E8E93"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btn_medium"
                            android:layout_width="0dp"
                            android:layout_height="64dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_participation_medium"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="✋" android:textSize="20sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Medium" android:textSize="12sp"
                                android:textColor="#1A5FA8" android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btn_high"
                            android:layout_width="0dp"
                            android:layout_height="64dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_attendance_unselected"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🙋" android:textSize="20sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="High" android:textSize="12sp"
                                android:textColor="#8E8E93"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- MOOD / ENERGY -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MOOD / ENERGY"
                        android:textSize="11sp"
                        android:textColor="#8E8E93"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/mood_focused"
                            android:layout_width="0dp"
                            android:layout_height="68dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_mood_selected"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="😊" android:textSize="22sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Focused" android:textSize="11sp"
                                android:textColor="#2E7D52" android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/mood_neutral"
                            android:layout_width="0dp"
                            android:layout_height="68dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_mood_unselected"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="😐" android:textSize="22sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Neutral" android:textSize="11sp"
                                android:textColor="#8E8E93"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/mood_tired"
                            android:layout_width="0dp"
                            android:layout_height="68dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_mood_unselected"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="😴" android:textSize="22sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Tired" android:textSize="11sp"
                                android:textColor="#8E8E93"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/mood_stressed"
                            android:layout_width="0dp"
                            android:layout_height="68dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_mood_unselected"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="😰" android:textSize="22sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Stressed" android:textSize="11sp"
                                android:textColor="#8E8E93"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- KEY TAKEAWAY -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KEY TAKEAWAY"
                        android:textSize="11sp"
                        android:textColor="#8E8E93"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="10dp"/>

                    <EditText
                        android:id="@+id/et_notes"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_note_box"
                        android:padding="12dp"
                        android:hint="What did you learn today?"
                        android:textColorHint="#AAAAAA"
                        android:textColor="#1C1C1E"
                        android:textSize="14sp"
                        android:gravity="top"
                        android:inputType="textMultiLine"
                        android:maxLines="4"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SAVE BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Save Entry"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#6B93D6"
                app:cornerRadius="26dp"
                android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>