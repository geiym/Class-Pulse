<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardSubject"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#C8E6C9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="16dp"
        android:paddingStart="14dp"
        android:paddingEnd="10dp">

        <!-- Delete mode checkbox -->
        <CheckBox
            android:id="@+id/cbDeleteSelect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:visibility="gone"
            android:buttonTint="#1C1C1E"/>

        <!-- Subject Icon -->
        <ImageView
            android:id="@+id/ivSubjectIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_subject_default"
            android:contentDescription="Subject icon"
            android:scaleType="centerCrop"/>

        <!-- Subject Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvSubjectName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subject Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1C1C1E"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvSubjectSchedule"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mon/Wed 8:00 AM - 4:00 PM"
                android:textSize="12sp"
                android:textColor="#555555"
                android:layout_marginTop="2dp"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Chevron (hidden in delete mode) -->
        <ImageView
            android:id="@+id/ivChevron"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_right"
            android:alpha="0.5"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>