<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp">

        <!-- Title Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvYour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your "
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1C1C1E"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvSubjects"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subjects"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#5B8DCC"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Color strip -->
        <include layout="@layout/view_color_strip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"/>

        <!-- Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|end"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnAddSubject"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="ADD A SUBJECT"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.05"
                android:background="@drawable/bg_btn_primary"
                android:paddingHorizontal="16dp"
                android:fontFamily="sans-serif-medium"
                style="?android:attr/borderlessButtonStyle"/>

            <ImageButton
                android:id="@+id/btnDeleteMode"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_delete"
                android:background="@drawable/bg_btn_delete_icon"
                android:layout_marginStart="10dp"
                android:contentDescription="Delete subject"
                android:padding="8dp"/>
        </LinearLayout>

        <!-- Scrollable content: subject list + Delete all -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Subject List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSubjects"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false"/>

                <!-- Delete All — appears directly below last subject card -->
                <TextView
                    android:id="@+id/tvDeleteAll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Delete all"
                    android:textSize="16sp"
                    android:textColor="#1C1C1E"
                    android:textStyle="bold"
                    android:paddingVertical="14dp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"/>

                <!-- Empty State -->
                <LinearLayout
                    android:id="@+id/layoutEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="60dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_subject_empty"
                        android:alpha="0.4"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No subjects yet"
                        android:textSize="17sp"
                        android:textColor="#8E8E93"
                        android:layout_marginTop="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text='Tap "ADD A SUBJECT" to get started'
                        android:textSize="14sp"
                        android:textColor="#AEAEB2"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>