<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Month nav row — pill shaped like reference -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_stat_pill"
        android:paddingHorizontal="12dp"
        android:layout_gravity="center_horizontal">

        <ImageButton
            android:id="@+id/btnMonthPrev"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_chevron_left"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Previous month"/>

        <TextView
            android:id="@+id/tvMonthLabel"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="April 2026"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1C1C1E"/>

        <ImageButton
            android:id="@+id/btnMonthNext"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_chevron_right"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Next month"/>
    </LinearLayout>

    <!-- Attendance This Month Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ATTENDANCE THIS MONTH"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#8E8E93"
                android:letterSpacing="0.05"
                android:layout_marginBottom="14dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Pie chart — larger to match reference -->
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChartMonthly"
                    android:layout_width="130dp"
                    android:layout_height="130dp"/>

                <!-- Legend with progress bars -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <!-- Present -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="52dp" android:layout_height="wrap_content"
                            android:text="Present" android:textSize="12sp"
                            android:textColor="#5CAD72" android:textStyle="bold"/>
                        <ProgressBar android:id="@+id/pbMonthPresent"
                            android:layout_width="0dp" android:layout_height="6dp"
                            android:layout_weight="1"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:progressDrawable="@drawable/progress_bar_green"
                            android:progress="80"/>
                        <TextView android:id="@+id/tvMonthPresentCount"
                            android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="16" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="#1C1C1E" android:gravity="end"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- Late -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="52dp" android:layout_height="wrap_content"
                            android:text="Late" android:textSize="12sp"
                            android:textColor="#E0A050" android:textStyle="bold"/>
                        <ProgressBar android:id="@+id/pbMonthLate"
                            android:layout_width="0dp" android:layout_height="6dp"
                            android:layout_weight="1"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:progressDrawable="@drawable/progress_bar_orange"
                            android:progress="15"/>
                        <TextView android:id="@+id/tvMonthLateCount"
                            android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="3" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="#1C1C1E" android:gravity="end"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- Absent -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView android:layout_width="52dp" android:layout_height="wrap_content"
                            android:text="Absent" android:textSize="12sp"
                            android:textColor="#D95F6A" android:textStyle="bold"/>
                        <ProgressBar android:id="@+id/pbMonthAbsent"
                            android:layout_width="0dp" android:layout_height="6dp"
                            android:layout_weight="1"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:progressDrawable="@drawable/progress_bar_red"
                            android:progress="0"/>
                        <TextView android:id="@+id/tvMonthAbsentCount"
                            android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="0" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="#D95F6A" android:gravity="end"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- HIGHLIGHTS THIS MONTH label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HIGHLIGHTS THIS MONTH"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#555555"
        android:letterSpacing="0.05"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp"/>

    <!-- Row 1: Best streak + Best days -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#C8E6C9">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔥" android:textSize="22sp"/>
                <TextView android:id="@+id/tvBestStreak"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="5 days" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="#1C1C1E" android:layout_marginTop="3dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Best streak" android:textSize="11sp" android:textColor="#555555"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#C5D8F0">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚡" android:textSize="22sp"/>
                <TextView android:id="@+id/tvBestDays"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Mon &amp; Fri" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="#1C1C1E" android:gravity="center"
                    android:layout_marginTop="3dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Best days" android:textSize="11sp" android:textColor="#555555"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Row 2: Weakest day + Notes logged -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F5E6C0">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📉" android:textSize="22sp"/>
                <TextView android:id="@+id/tvWeakestDay"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Wed" android:textSize="18sp" android:textStyle="bold"
                    android:textColor="#1C1C1E" android:layout_marginTop="3dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Weakest day" android:textSize="11sp" android:textColor="#555555"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#DDD0EE">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📝" android:textSize="22sp"/>
                <TextView android:id="@+id/tvNotesLogged"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="12" android:textSize="18sp" android:textStyle="bold"
                    android:textColor="#1C1C1E" android:layout_marginTop="3dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Notes logged" android:textSize="11sp" android:textColor="#555555"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Mood This Month Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MOOD THIS MONTH"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1C1C1E"
                android:letterSpacing="0.04"
                android:layout_marginBottom="16dp"/>

            <!-- Mood rows — indented with paddingStart -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="4dp">

                <!-- Happy -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="😊 Happy" android:textSize="13sp" android:textColor="#1C1C1E"/>
                    <ProgressBar android:id="@+id/pbMoodHappy"
                        android:layout_width="0dp" android:layout_height="6dp"
                        android:layout_weight="1"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:progressDrawable="@drawable/progress_bar_green"
                        android:progress="50"/>
                    <TextView android:id="@+id/tvMoodHappyPct"
                        android:layout_width="40dp" android:layout_height="wrap_content"
                        android:text="50%" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#5CAD72"
                        android:gravity="end" android:layout_marginStart="10dp"/>
                </LinearLayout>

                <!-- Neutral -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="😐 Neutral" android:textSize="13sp" android:textColor="#1C1C1E"/>
                    <ProgressBar android:id="@+id/pbMoodNeutral"
                        android:layout_width="0dp" android:layout_height="6dp"
                        android:layout_weight="1"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:progressDrawable="@drawable/progress_bar_orange"
                        android:progress="30"/>
                    <TextView android:id="@+id/tvMoodNeutralPct"
                        android:layout_width="40dp" android:layout_height="wrap_content"
                        android:text="30%" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#E0A050"
                        android:gravity="end" android:layout_marginStart="10dp"/>
                </LinearLayout>

                <!-- Stressed -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="😰 Stressed" android:textSize="13sp" android:textColor="#1C1C1E"/>
                    <ProgressBar android:id="@+id/pbMoodStressed"
                        android:layout_width="0dp" android:layout_height="6dp"
                        android:layout_weight="1"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:progressDrawable="@drawable/progress_bar_red"
                        android:progress="20"/>
                    <TextView android:id="@+id/tvMoodStressedPct"
                        android:layout_width="40dp" android:layout_height="wrap_content"
                        android:text="20%" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#D95F6A"
                        android:gravity="end" android:layout_marginStart="10dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Class Check-In -->
    <include layout="@layout/card_class_checkin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"/>

</LinearLayout>